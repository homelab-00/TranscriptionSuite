{
  "mcpServers": {
    "deepwiki": {
      "type": "http",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp"
    },
    "fetch": {
      "args": ["mcp-server-fetch"],
      "command": "uvx"
    },
    "filesystem": {
      "args": ["-y", "@modelcontextprotocol/server-filesystem", ""],
      "command": "npx"
    },
    "git": {
      "args": ["mcp-server-git"],
      "command": "uvx"
    }
  }
}
